# CosyVoice2 requires CUDA 12.1 runtime + Python 3.10
FROM nvidia/cuda:12.1.1-cudnn8-runtime-ubuntu22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

RUN apt-get update && apt-get install -y --no-install-recommends \
    python3.10 \
    python3.10-dev \
    python3-pip \
    git \
    libsndfile1 \
    sox \
    libsox-dev \
    ffmpeg \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

RUN ln -sf /usr/bin/python3.10 /usr/bin/python3
RUN ln -sf /usr/bin/python3 /usr/bin/python

# Install torch 2.3.1 for cu121 (matches CosyVoice requirements)
RUN pip install --no-cache-dir \
    torch==2.3.1+cu121 \
    torchaudio==2.3.1+cu121 \
    --index-url https://download.pytorch.org/whl/cu121

# Clone CosyVoice with submodules (AcademiCodec, Matcha-TTS)
RUN git clone --recursive https://github.com/FunAudioLLM/CosyVoice /cosyvoice

WORKDIR /cosyvoice

# Install CosyVoice runtime dependencies (from their requirements.txt)
# Skipping: torch (already installed), modelscope mirror, training-only pkgs
RUN pip install --no-cache-dir \
    conformer==0.3.2 \
    diffusers==0.29.0 \
    transformers==4.51.3 \
    librosa==0.10.2 \
    soundfile==0.12.1 \
    hydra-core==1.3.2 \
    omegaconf==2.3.0 \
    HyperPyYAML==1.2.3 \
    lightning==2.2.4 \
    x-transformers==2.11.24 \
    einops \
    networkx==3.1 \
    numpy==1.26.4 \
    pyworld==0.3.4 \
    pydantic==2.7.0 \
    grpcio==1.57.0 \
    grpcio-tools==1.57.0 \
    protobuf==4.25.3 \
    huggingface_hub \
    openai-whisper==20231117 \
    inflect \
    fastapi==0.115.6 \
    uvicorn[standard]==0.30.0

# wetext: Chinese/multilingual text normalization (needed by CosyVoice)
RUN pip install --no-cache-dir wetext==0.0.4 || true

# onnxruntime-gpu for accelerated speaker encoder
RUN pip install --no-cache-dir onnxruntime-gpu==1.18.0 || true

# modelscope (may be imported internally by CosyVoice)
RUN pip install --no-cache-dir modelscope || true

# Download CosyVoice2-0.5B model weights at build time
RUN python3 -c "\
from huggingface_hub import snapshot_download; \
snapshot_download('FunAudioLLM/CosyVoice2-0.5B', local_dir='/models/CosyVoice2-0.5B')"

COPY app.py /app/app.py
WORKDIR /app

EXPOSE 8032
CMD ["uvicorn", "app:app", "--host", "0.0.0.0", "--port", "8032"]
